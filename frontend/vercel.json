{
  "rewrites": [
    {
      "source": "/o/:slug/manifest.json",
      "destination": "https://bento-app-qt5c.onrender.com/api/pwa/o/:slug/manifest.json"
    },
    {
      "source": "/free/manifest.json",
      "destination": "https://bento-app-qt5c.onrender.com/api/pwa/free/manifest.json"
    },
    {
      "source": "/o/:slug/icon-192.png",
      "destination": "https://bento-app-qt5c.onrender.com/api/pwa/o/:slug/icon-192.png"
    },
    {
      "source": "/o/:slug/icon-512.png",
      "destination": "https://bento-app-qt5c.onrender.com/api/pwa/o/:slug/icon-512.png"
    },
    // 静的ファイル保護
    {
      "source": "/favicon.ico",
      "destination": "/favicon.ico"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },

    // SPA fallback
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
